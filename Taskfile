#!/bin/bash

RM=rm

function clean {    # Clean binaries
    $RM -rf bin
    $RM -rf test_mkdir_tmpdir
}

function build {    # Build {compiler:gcc} {optimizationchar:0}
  mkdir -p bin
  CC=${1:-gcc}
  OPT=${2:-z}

  case $CC in
    gcc)
      LDFLAGS=-fwhole-program
      ;;
    clang)
      LDFLAGS=-flto
      ;;
    mingw-gcc)
      LDLIBS=-lkernel32
      ;;
  esac

  for f in tests/*.c examples/*.c; do
    x="${f##*/}"
    x="${x%.*}";
    $CC -I. -static -fno-builtin -fno-asynchronous-unwind-tables -fomit-frame-pointer -ffunction-sections -fdata-sections -Wl,--gc-sections,--build-id=none -s -Wall -Wextra -Wpedantic -O$OPT $LDFLAGS $f -ffreestanding -nostdlib -lgcc $LDLIBS -o bin/$x  
  done
}

function build_arm {    # Build for ARM (armhf/armv7) {compiler:arm-linux-gnueabihf-gcc} {optimizationchar:3}
  mkdir -p bin
  CC=${1:-arm-linux-gnueabihf-gcc}
  OPT=${2:-z}

  LDFLAGS=""
  LINK_LIB="-lgcc"

  case $CC in
    gcc)
      CC=arm-linux-gnueabihf-gcc
      ;;
    clang)
      # ARM clang uses -Os (not -Oz) to avoid __aeabi_idiv calls that need libgcc,
      # whose div-by-zero handler calls raise() which we don't have.
      OPT=s
      LDFLAGS="--target=arm-linux-gnueabihf --sysroot=/usr/arm-linux-gnueabihf -flto"
      LINK_LIB=""
      ;;
  esac

  for f in tests/*.c examples/*.c; do
    x="${f##*/}"
    x="${x%.*}";
    $CC -I. -static -fno-builtin -fno-asynchronous-unwind-tables -fomit-frame-pointer -ffunction-sections -fdata-sections -Wl,--gc-sections,--build-id=none -s -Wall -Wextra -Wpedantic -O$OPT $LDFLAGS $f -ffreestanding -nostdlib $LINK_LIB -o bin/$x.armhf
  done
}

